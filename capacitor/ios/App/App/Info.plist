		<string>zh-Hant</string>
	</array>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>LSSupportsOpeningDocumentsInPlace</key>
	<true/>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoadsInWebContent</key>
		<true/>
	</dict>
	<key>NSCameraUsageDescription</key>
	<string>This app uses the camera to capture photos for tagging.</string>
	<key>NSDocumentsFolderUsageDescription</key>
	<string>TagSpaces needs access to your documents folder to organize, tag, and search your files.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>This app uses the microphone to record voice memos and audio notes.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>This app requires photo library access to save photos.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>This app requires photo library access to organize and tag your photos.</string>
	<key>NSUbiquitousContainers</key>
	<dict>
		<key>iCloud.org.tagspaces.mobileapp</key>
		<dict>
			<key>NSUbiquitousContainerIsDocumentScopePublic</key>
			<true/>
			<key>NSUbiquitousContainerSupportedFolderLevels</key>
			<string>Any</string>
			<key>NSUbiquitousContainerName</key>
			<string>TagSpaces</string>
		</dict>
	</dict>
